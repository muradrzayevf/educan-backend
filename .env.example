# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/educan
DB_SSL=false

# JWT — production-da uzun, təsadüfi sətirlə əvəz et (məs: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ===== Ödəniş =====
# Seçimlər: stub | square | kapital | dodo
# stub  → balans birbaşa kreditlənir (açarsız, lokal/test)
# square→ Square Web Payments SDK (kart) — sandbox/test üçün
# kapital→ Kapital Bank TXPG (real, AZ production)
# dodo  → Dodo Payments (hosted checkout + webhook) — sandbox/test üçün
PAYMENT_PROVIDER=stub

# ===== Dodo Payments (test/sandbox) =====
DODO_ENV=test                 # test → test.dodopayments.com ; live → live.dodopayments.com
DODO_API_KEY=                 # GİZLİ — Dashboard → Developer → API (test açarı 'test_...')
DODO_WEBHOOK_SECRET=          # GİZLİ — Dashboard → Developer → Webhooks ('whsec_...')
DODO_PRODUCT_ID=              # Dashboard → Products → məhsulun ID-si (pdt_.../prod_...)
DODO_PWYW=false               # məhsul "Pay What You Want"-dursa true (məbləği biz göndəririk)

# ===== Square (sandbox/test) =====
SQUARE_ENV=sandbox
SQUARE_ACCESS_TOKEN=          # GİZLİ — Developer Dashboard → Sandbox access token
SQUARE_APP_ID=                # public — sandbox-sq0idb-...
SQUARE_LOCATION_ID=           # public — sandbox location id
SQUARE_CURRENCY=USD           # sandbox: USD (Square AZN dəstəkləmir)
# SQUARE_VERSION=2025-01-23

# Bankın verdiyi login/parol (test sandbox: TerminalSys/kapital + kapital123)
KAPITAL_LOGIN=
KAPITAL_PASSWORD=
# true = test mühiti (txpgtst.kapitalbank.az), false = canlı (production)
KAPITAL_IS_DEV=true

# Backend-in PUBLIC ünvanı — bank ödənişdən sonra brauzeri buraya qaytarır.
# Lokal: http://localhost:4000 ; production: https://api.educan.az
PUBLIC_BASE_URL=http://localhost:4000

# ===== Zoom =====
# API inteqrasiyası YOXDUR. Müəllim görüşü Zoom-da özü yaradır, qoşulma linkini
# əl ilə slota yapışdırır; yazılışı da əl ilə (fayl və ya link) sayta əlavə edir.
# Heç bir ZOOM_* açarı lazım deyil.

# ===== Email (SMTP) =====
# Boş qalsa email-lər konsola yazılır (lokal/test).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=EduCan <no-reply@educan.az>

# ===== Auth v2: OTP + Google =====
# Email OTP kodunun etibarlılıq müddəti (dəqiqə)
OTP_TTL_MIN=10
# Google ilə giriş üçün OAuth Client ID (Google Cloud Console → APIs & Services → Credentials)
# → "OAuth 2.0 Client ID" (Web application). Boş qalsa Google düyməsi gizlənir.
# Authorized JavaScript origins-ə frontend domenini əlavə et (lokal: http://localhost:4000)
GOOGLE_CLIENT_ID=
AZN_PER_USD=1.7

# ===== Fayl saxlama (upload) =====
# local (default): fayllar serverin diskinə (uploads/) yazılır — lokal test üçün açar lazım deyil.
# r2: fayllar Cloudflare R2-yə (S3-uyğun) yüklənir, DB-də tam public URL saxlanılır.
# PaaS-də disk efemerdir (hər deploy-da itir) → prod-da r2 işlət.
STORAGE=local
# R2 endpoint kodda qurulur: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Bucket-ın public bazası — fayl URL-i bunun üstünə qurulur. Məs: https://cdn.educan.az və ya https://<hash>.r2.dev
R2_PUBLIC_URL=
